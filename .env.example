NODE_ENV=production
APP_URL=https://apps.aameel.top
DEFAULT_LOCALE=zh
SUPPORTED_LOCALES=zh,en

POSTGRES_PASSWORD=postgres_password
MEEL_APPS_DB_PASSWORD=password
UMAMI_DB_PASSWORD=password
DATABASE_URL=postgres://meel_apps_user:password@postgres:5432/meel_apps
UMAMI_DATABASE_URL=postgres://umami_user:password@postgres:5432/umami

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=change_me_to_a_long_random_secret

STORAGE_DRIVER=local
UPLOAD_DIR=/data/uploads
PUBLIC_UPLOAD_BASE_URL=/uploads
IMAGE_MAX_BYTES=10485760
DOWNLOAD_MAX_BYTES=314572800

UMAMI_URL=https://apps.aameel.top/stats
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=
UMAMI_HASH_SALT=change_me_umami_salt
