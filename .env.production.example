NODE_ENV=production
APP_URL=https://apps.aameel.top
DEFAULT_LOCALE=zh
SUPPORTED_LOCALES=zh,en

POSTGRES_PASSWORD=replace_with_strong_postgres_admin_password
MEEL_APPS_DB_PASSWORD=replace_with_strong_apps_db_password
UMAMI_DB_PASSWORD=replace_with_strong_umami_db_password

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=replace_with_64_chars_random_secret

STORAGE_DRIVER=local
UPLOAD_DIR=/data/uploads
PUBLIC_UPLOAD_BASE_URL=/uploads
IMAGE_MAX_BYTES=10485760
DOWNLOAD_MAX_BYTES=314572800

UMAMI_URL=https://apps.aameel.top/stats
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=
UMAMI_HASH_SALT=replace_with_strong_umami_hash_salt
UMAMI_APP_SECRET=replace_with_strong_umami_app_secret
